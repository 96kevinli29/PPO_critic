# 复制为 .env 后按需填写（.env 已加入 .gitignore，勿提交密钥）
#
# Weights & Biases（若使用 W&B）
# WANDB_API_KEY=
# WANDB_PROJECT=
#
# Hugging Face（拉 gated 模型时需要）
# HF_TOKEN=
#
# 国内或访问 hub 较慢时，使用 hf-mirror（与 HF_TOKEN 可同时配置）
# HF_ENDPOINT=https://hf-mirror.com
#
# 一般不要设置 RAY_TMPDIR 指向仓库内长路径；hyl_env.sh 会改用短路径并维护 ray_tmp 符号链接。
# RAY_TMPDIR=
